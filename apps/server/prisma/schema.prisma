// This is your Prisma schema file
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output          = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  githubId       String   @unique @map("github_id")
  githubUsername String   @map("github_username")
  avatarUrl      String?  @map("avatar_url")
  accessToken    String?  @map("access_token")
  createdAt      DateTime @default(now()) @map("created_at")

  roomMembers          RoomMember[]
  privateRoomSessions  PrivateRoomSession[]
  chatMessages         ChatMessage[]
  hostedMeetings       Meeting[]            @relation("MeetingHost")
  meetingParticipants  MeetingParticipant[]
  minutes              Minutes[]            @relation("MinutesAuthor")
  todos                Todo[]
  notifications        Notification[]

  @@map("user")
}

model Room {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  inviteCode  String   @unique @map("invite_code")
  maxMembers  Int      @default(6) @map("max_members")
  status      String   @default("active") // active | completed
  createdAt   DateTime @default(now()) @map("created_at")

  members      RoomMember[]
  repos        Repo[]
  privateRoom  PrivateRoom[]
  chatMessages ChatMessage[]
  meetings     Meeting[]
  minutes      Minutes[]
  todos        Todo[]
  notifications Notification[]

  @@map("room")
}

model RoomMember {
  id            String   @id @default(uuid()) @db.Uuid
  roomId        String   @map("room_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  role          String?  // frontend | backend | design | qa | devops | reviewer | etc
  characterType String?  @map("character_type") // circle | square | triangle | star | moon | cloud
  nickname      String?
  status        String   @default("focus") // focus | rest | meeting | away
  isHost        Boolean  @default(false) @map("is_host")
  posX          Int      @default(0) @map("pos_x")
  posY          Int      @default(0) @map("pos_y")
  joinedAt      DateTime @default(now()) @map("joined_at")

  room Room @relation(fields: [roomId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("room_member")
}

model Repo {
  id              String    @id @default(uuid()) @db.Uuid
  roomId          String    @map("room_id") @db.Uuid
  fullName        String    @map("full_name") // owner/repo-name
  defaultBranch   String    @default("main") @map("default_branch")
  webhookId       String?   @map("webhook_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  statsCache      Json?     @map("stats_cache") // 마지막으로 조회한 stats 저장
  statsCachedAt   DateTime? @map("stats_cached_at") // 언제 캐싱했는지

  room Room @relation(fields: [roomId], references: [id])

  @@map("repo")
}

model PrivateRoom {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @map("room_id") @db.Uuid // 룸당 최대 2개
  name      String   @default("회의실")
  createdAt DateTime @default(now()) @map("created_at")

  room     Room                 @relation(fields: [roomId], references: [id])
  sessions PrivateRoomSession[]
  chatMessages ChatMessage[]
  meetings Meeting[]

  @@map("private_room")
}

model PrivateRoomSession {
  id            String    @id @default(uuid()) @db.Uuid
  privateRoomId String    @map("private_room_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  enteredAt     DateTime  @default(now()) @map("entered_at")
  leftAt        DateTime? @map("left_at") // null = 현재 입장 중

  privateRoom PrivateRoom @relation(fields: [privateRoomId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@map("private_room_session")
}

model ChatMessage {
  id            String   @id @default(uuid()) @db.Uuid
  roomId        String   @map("room_id") @db.Uuid
  privateRoomId String?  @map("private_room_id") @db.Uuid // null = 메인룸 채팅
  userId        String   @map("user_id") @db.Uuid
  content       String
  type          String   @default("text") // text | meeting_start | meeting_end
  createdAt     DateTime @default(now()) @map("created_at")

  room        Room         @relation(fields: [roomId], references: [id])
  privateRoom PrivateRoom? @relation(fields: [privateRoomId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@map("chat_message")
}

model Meeting {
  id            String    @id @default(uuid()) @db.Uuid
  roomId        String    @map("room_id") @db.Uuid
  privateRoomId String    @map("private_room_id") @db.Uuid
  hostId        String    @map("host_id") @db.Uuid
  status        String    @default("ongoing") // ongoing | ended | cancelled
  startedAt     DateTime  @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")

  room        Room                 @relation(fields: [roomId], references: [id])
  privateRoom PrivateRoom          @relation(fields: [privateRoomId], references: [id])
  host        User                 @relation("MeetingHost", fields: [hostId], references: [id])
  participants MeetingParticipant[]
  minutes     Minutes?

  @@map("meeting")
}

model MeetingParticipant {
  id        String    @id @default(uuid()) @db.Uuid
  meetingId String    @map("meeting_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  meeting Meeting @relation(fields: [meetingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("meeting_participant")
}

model Minutes {
  id                  String    @id @default(uuid()) @db.Uuid
  meetingId           String?   @unique @map("meeting_id") @db.Uuid // null = 수동 작성
  roomId              String    @map("room_id") @db.Uuid
  authorId            String    @map("author_id") @db.Uuid
  title               String
  type                String    // meeting | troubleshooting | etc
  contentMd           String?   @map("content_md")
  status              String    @default("draft") // draft | confirmed
  linkedIssueNumbers  Int[]     @map("linked_issue_numbers") // 발행된 GitHub 이슈 번호 배열
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  actionItems         Json?     @map("action_items") // 액션 아이템 전체 목록

  meeting Meeting? @relation(fields: [meetingId], references: [id])
  room    Room     @relation(fields: [roomId], references: [id])
  author  User     @relation("MinutesAuthor", fields: [authorId], references: [id])

  @@map("minutes")
}

model Todo {
  id                String   @id @default(uuid()) @db.Uuid
  roomId            String?  @map("room_id") @db.Uuid
  userId            String?  @map("user_id") @db.Uuid
  githubIssueNumber Int      @map("github_issue_number")
  isDone            Boolean  @default(false) @map("is_done")
  date              DateTime @db.Date // 오늘 날짜
  createdAt         DateTime @default(now()) @map("created_at")

  room Room? @relation(fields: [roomId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@map("todo")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @map("room_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   // pr_opened | pr_merged | minutes_generated | new_issue
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  room Room @relation(fields: [roomId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("notification")
}
