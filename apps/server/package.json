{
  "name": "todak-server",
  "version": "1.0.0",
  "description": "Todak - WebFullStack Server",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc && cp -R src/generated dist/generated",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@octokit/rest": "^21.1.1",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bullmq": "^5.52.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.6.1",
    "morgan": "^1.10.0",
    "openapi3-ts": "^4.4.0",
    "pg": "^8.16.0",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^4.6.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^7.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@9.15.9"
}
