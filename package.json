{
  "name": "todak",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Todak - WebFullStack Monorepo",
  "scripts": {
    "dev": "pnpm --filter todak-server dev",
    "dev:server": "pnpm --filter todak-server dev",
    "dev:client": "pnpm --filter todak-client dev",
    "build": "pnpm --filter todak-server build",
    "build:server": "pnpm --filter todak-server build",
    "build:client": "pnpm --filter todak-client build",
    "start": "pnpm --filter todak-server start",
    "start:server": "pnpm --filter todak-server start",
    "start:client": "pnpm --filter todak-client start",
    "lint": "pnpm --filter todak-server lint && pnpm --filter todak-client lint",
    "lint:fix": "pnpm --filter todak-server lint -- --fix && pnpm --filter todak-client lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter todak-server db:generate",
    "db:migrate": "pnpm --filter todak-server db:migrate",
    "db:push": "pnpm --filter todak-server db:push",
    "db:studio": "pnpm --filter todak-server db:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.4.1",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "prettier-plugin-prisma": "^5.0.0"
  },
  "lint-staged": {
    "apps/server/**/*.{ts,json}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/client/**/*.{ts,tsx,js,jsx,json,css}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9"
}
